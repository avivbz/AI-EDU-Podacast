# Copy this file to `.env` and fill in your real key. `.env` is gitignored.
# Get a key in Google Cloud console with the Cloud Text-to-Speech API enabled.
GOOGLE_TTS_API_KEY=your-google-cloud-tts-api-key-here

# Optional overrides (defaults shown):
# SITE_BASE_URL=https://avivbz.github.io/AI-EDU-Podacast
# TTS_VOICE=en-US-Neural2-J
# TTS_LANGUAGE_CODE=en-US
